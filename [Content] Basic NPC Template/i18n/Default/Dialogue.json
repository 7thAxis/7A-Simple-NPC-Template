{

// Dialogue commands and formatting Wiki page - https://stardewvalleywiki.com/Modding:Dialogue

  "Dialogue.Mon": "Hello, this is some basic dialogue!",
  "Dialogue.Tue": "This is dialogue using a portrait changing command!$h",
    /*  
        Portrait commands can be used in two different ways, here's a small chart for reference.
            
        |  $0  |    | - Neutral
        |  $1  | $h | - Happy
        |  $2  | $s | - Sad
        |  $3  | $u | - Custom
        |  $4  | $l | - Love
        |  $5  | $a | - angry
        |  $6+ | $a | - Custom
    */
  "Dialogue.Wed": "This is a dialogue that utilizes two text boxes.#$b#Isn't that cool?$h",
  "Dialogue.Thu": "This is dialogue that requires you to interact with the NPC again to continue.#$e#Congrats, you interacted with me again!$h",

    // Dialogue can be broken up in a few ways. The onces you'll typically find yourself using are...
        // #$b# - Waits for you to click the current dialogue box for the next to appear. Good for preventing run-on dialogue boxes.
        // #$e# - Stops the dialogue, making you have to click the NPC again to continue. Good for letting your NPC ramble, but not trap the player.

  "Dialogue.Fri": "$query WEATHER Here Rain#A Rainy Friday, yuck...|This is an example of a conditional dialogue. This is the text that displays when it's false! In this case, it is not raining this friday.",
  "Dialogue.Sat": "This is an example of a simple question.#$b#$y 'Is this cool?_Yes_You said yes!_No_You said no!_Maybe_You said maybe!'",
  "Dialogue.Sun": "This is an example of a dialogue that gives you an item![270]#$b#This is an example of a dialogue that gives you an item with more specifics. Specifically 10 silver star corn.#$action AddItem 270 10 1",

    // This example includes an action command, which allows you to preform a whole array of behaviors following a dialogue.
    // You must use # between your dialogue and the command or it may not work properly.
    // For a list of vanilla action commands, view this page: https://stardewvalleywiki.com/Modding:Trigger_actions

