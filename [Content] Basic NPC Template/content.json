        "AlternateNPCArt": {
                // Name of your config. 
                // You can make this display different in GMCM via i18n.
            "AllowValues": "true, false",
            "Default": false,
            "AllowBlank": false,
            "Description":"Example config that uses different portraits and sprites for the NPC.",
            "Section": "Graphics"
                // See "Data/Appearance.json" for this being configuration used.
        },
        "TestConfig": {
            "AllowValues": "Option1, Option2, Option3",
            "Default": "Option1",
            "AllowBlank": false,
            "Description":"A config that does nothing, but shows how to do a dropdown list.\nDelete it if you don't need it.",
                // \n creates a break-line in certain locations where text can be added.
            "Section": "Test"
        }
    },

    //"DynamicTokens": {},

    "Changes": [
        {
            "LogName": "Import File Loader",
            "Action": "Include",
            "FromFile": "Loaders/File_Loader.json"
        }
        // This will load the file (Data/Loaders/File_Loader.json) that contains all data loading.
        // You can technically put them here in content.json, but as mods get larger it gets unruly.
        // As such, I've found moving data importing into its own file to be less overwhelming.
    ]

