{
    "Format": "2.6.0",
    "ConfigSchema": {

        // See "i18n/Default/Config.json" to see how to make translation keys for configs.
        // Configuration documentation - https://github.com/Pathoschild/StardewMods/blob/develop/ContentPatcher/docs/author-guide/config.md
        // Be sure to install Generic Mod Config Menu for easier configuration testing

        "AlternateNPCArt": {
                // Name of your config. 
                // You can make this display different in GMCM via i18n.
            "AllowValues": "true, false",
            "Default": false,
            "AllowBlank": false,
            "Description":"Example config that uses different portraits and sprites for the NPC.",
            "Section": "Graphics"
                // See "Data/Appearance.json" for this being configuration used.
        },
        "TestConfig": {
            "AllowValues": "Option1, Option2, Option3",
            "Default": "Option1",
            "AllowBlank": false,
            "Description":"A config that does nothing, but shows how to do a dropdown list.\nDelete it if you don't need it.",
                // \n creates a break-line in certain locations where text can be added.
            "Section": "Test"
        }
    },

    "DynamicTokens": [

        // Dynamic tokens are essentially custom variables that content patcher doesn't provide that you define yourself.
        // You can use these in when conditions to enable and disable patches, among other things.
            // Dynamic token documentation -

        // Token Defaults
            // It is always best practice to have default value for a token to prevent potential errors
            // EX: You are on the save load screen where the values don't exist

        { "Name": "TodaysDate", "Value": "N/A" },
        { "Name": "IsEggFestivalToday", "Value": false },

        //Token Conditions
        {
            "Name": "TodaysDate",
            "Value": "{{Season}} {{Day}}"     
                // This token will resolve to the current Season and Day (ex: Spring 1), essentially merging the tokens.
        },
        {
            "Name": "IsSpringFestivalToday",
            "Value": true,
            "When": { "TodaysDate": "Spring 13, Spring 24" }
                // This token is checking if the previous token, Today's date is Spring 13 or Spring 24, the days of spring festivals.
                // This token isn't necessarily very useful, just an example.
                // If you want to check this you can just use the when condition on this token elsewhere in the mod.
        }

    ],

    "Changes": [
        {
            "LogName": "Import File Loader",
            "Action": "Include",
            "FromFile": "Loaders/File_Loader.json"
        }
        // This will load the file (Data/Loaders/File_Loader.json) that contains all data loading.
        // You can technically put them here in content.json, but as mods get larger it gets unruly.
        // As such, I've found moving data importing into its own file to be less overwhelming.
    ]


    //  FIX INTERIOR MAP COLISSION


}
